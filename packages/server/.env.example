DATABASE_URL=postgres://nps:nps@localhost:5432/limechat_nps
PORT=4000
# Comma-separated. "*" allows any origin (dev only).
CORS_ORIGINS=*
# Server-side admin/service key (service-to-service analytics + BI export jobs).
ADMIN_API_KEY=sk_admin_change_me
# Comma-separated public write keys accepted from the widget.
WRITE_KEYS=pk_live_demo,pk_test_demo
# Secret used to sign dashboard login sessions (HS256). Use a long random value.
JWT_SECRET=change_me_to_a_long_random_string
# Optional: bootstrap the first admin non-interactively (used by create-admin).
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
